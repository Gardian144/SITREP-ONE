      "date": "29/06",
      "timestamp": 1782747681
    },
    {
      "id": "BFMTV_1782747559",
      "source": "BFMTV",
      "text": "CHRISTOPHE GLEIZES: \"LE TEMPS POUR LUI EST TRÈS LONG\" REGRETTE SA MÈRE",
