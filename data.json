      "france_related": true,
      "time": "06:09",
      "date": "29/06",
      "timestamp": 1782713390
    },
    {
      "id": "BFMTV_1782707796",
      "source": "BFMTV",
      "text": "LES ÉTATS-UNIS ANNONCENT UNE SUSPENSION MUTUELLE DES HOSTILITÉS AVEC L'IRAN \"POUR LE MOMENT\"",
      "urgent": true,
      "france_related": false,
      "time": "04:36",
      "date": "29/06",
      "timestamp": 1782707796
    },
    {
      "id": "BFMTV_1782683285",
      "source": "BFMTV",
      "text": "\"ON FAIT LA QUEUE PENDANT 1H30\": SUITE AUX FRAPPES UKRAINIENNES EN RUSSIE, LE PAYS FAIT FACE À UNE PÉNURIE DE CARBURANT",
