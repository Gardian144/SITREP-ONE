      "time": "10:20",
      "date": "29/06",
      "timestamp": 1782728450
    },
    {
      "id": "BFMTV_1782727774",
      "source": "BFMTV",
      "text": "AU MOINS 117 CHIENS MORTS RETROUVÉS AU SEIN D’UN REFUGE SE REVENDIQUANT \"SANS EUTHANASIE\" EN CALIFORNIE",
