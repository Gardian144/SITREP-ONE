      "france_related": false,
      "time": "18:48",
      "date": "28/06",
      "timestamp": 1782672490
    },
    {
      "id": "BFMTV_1782672286",
      "source": "BFMTV",
      "text": "DONALD TRUMP ESTIME \"QUE L'UKRAINE EST EN ASSEZ BONNE POSITION\" DANS LA GUERRE CONTRE LA RUSSIE",
      "urgent": true,
      "france_related": false,
      "time": "18:44",
      "date": "28/06",
      "timestamp": 1782672286
    },
    {
      "id": "BFMTV_1782671872",
      "source": "BFMTV",
      "text": "L'UKRAINE SE FIXE UN DÉLAI DE 40 JOURS POUR PROVOQUER LA CAPITULATION DE LA RUSSIE ET DE VLADIMIR POUTINE",
      "urgent": false,
      "france_related": false,
      "time": "18:37",
      "date": "28/06",
      "timestamp": 1782671872
    },
    {
      "id": "BFMTV_1782671769",
      "source": "BFMTV",
      "text": "UN FRANÇAIS ARRÊTÉ AU ROYAUME-UNI POUR LE MEURTRE ET LE VIOL D'UNE ENFANT DE DEUX ANS",
      "urgent": false,
      "france_related": true,
      "time": "18:36",
      "date": "28/06",
      "timestamp": 1782671769
    },
    {
      "id": "BFMTV_1782662252",
      "source": "BFMTV",
      "text": "EN PLEIN MONDIAL AUX ÉTATS-UNIS, CES MIGRANTS JOUENT AU FOOTBALL SOUS LA MENACE DE L'ICE",
      "urgent": false,
      "france_related": false,
      "time": "15:57",
      "date": "28/06",
      "timestamp": 1782662252
    },
    {
      "id": "BFMTV_1782657662",
      "source": "BFMTV",
      "text": "GUERRE IA: QUI EST CET ENTREPRENEUR DE LA TECH TRÈS PROCHE DE TRUMP ",
