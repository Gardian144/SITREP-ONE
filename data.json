      "urgent": false,
      "france_related": true,
      "time": "10:07",
      "date": "29/06",
      "timestamp": 1782727673
    },
    {
      "id": "BFMTV_1782727013",
      "source": "BFMTV",
      "text": "DÉTROIT D'ORMUZ: LE SULTAN D'OMAN REÇU PAR EMMANUEL MACRON À L'ÉLYSÉE CE LUNDI",
