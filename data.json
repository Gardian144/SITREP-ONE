    },
    {
      "id": "BFMTV_1782726079",
      "source": "BFMTV",
      "text": "VLADIMIR POUTINE RECONNAÎT \"UNE CERTAINE PÉNURIE\" DE CARBURANT EN RUSSIE À CAUSE DES FRAPPES UKRAINIENNES",
