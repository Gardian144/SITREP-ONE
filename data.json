      "france_related": false,
      "time": "20:29",
      "date": "28/06",
      "timestamp": 1782678594
    },
    {
      "id": "BFMTV_1782673582",
      "source": "BFMTV",
      "text": "40 JOURS POUR FAIRE CÉDER LA RUSSIE: \"SUR LE FRONT, LES UKRAINIENS AVANCENT\", ANALYSE BERNARD-HENRI LÉVY, ÉCRIVAIN",
