      "time": "15:39",
      "date": "29/06",
      "timestamp": 1782747559
    },
    {
      "id": "BFMTV_1782747363",
      "source": "BFMTV",
      "text": "CHRISTOPHE GLEIZES: \"LE MORAL COMMENCE À DÉCLINER\", ASSURE SA MÈRE CAR \"IL EST TOTALEMENT COUPÉ DU MONDE\"",
