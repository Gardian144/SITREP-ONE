    },
    {
      "id": "BFMTV_1782738736",
      "source": "BFMTV",
      "text": "ALLEMAGNE: EN RAISON DE LA CANICULE, LA POLICE ARROSE LES BERLINOIS AVEC DES CANONS À EAU",
