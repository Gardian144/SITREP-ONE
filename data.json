    },
    {
      "id": "BFMTV_1782713390",
      "source": "BFMTV",
      "text": "GUERRE AU MOYEN-ORIENT: UN NAVIRE FRANÇAIS PASSE LE DÉTROIT D'ORMUZ, LE COMMANDANT TÉMOIGNE",
