      "france_related": false,
      "time": "09:56",
      "date": "29/06",
      "timestamp": 1782727013
    },
    {
      "id": "BFMTV_1782726756",
      "source": "BFMTV",
      "text": "UN VASTE COMPLEXE DE LOGEMENTS DE L'ÈRE CHAVEZ DÉTRUIT PAR LE DOUBLE SÉISME AU VENEZUELA",
      "urgent": false,
      "france_related": false,
      "time": "09:52",
      "date": "29/06",
